# Optional — only used to label the maintainer in .menu/.owner replies.
# You do NOT set your number here: open the web dashboard this bot serves
# (the Railway/Render URL, or http://localhost:3000 locally) — every
# visitor requests their own pairing code from there.
OWNER_NUMBER=12136061765

# Max number of WhatsApp accounts that can be paired to this deployment at
# once. Each paired account keeps its own live connection running, which
# costs RAM — raise this only as far as your hosting plan's memory allows.
MAX_SESSIONS=5

# Command prefix
PREFIX=.

# Server port (most hosting platforms set this automatically)
PORT=3000

# Auto Status View — automatically mark contacts' status updates as seen
AUTO_STATUS_VIEW=true

# Auto Status React — also auto-react to statuses with AUTO_STATUS_EMOJI (off by default)
AUTO_STATUS_REACT=false
AUTO_STATUS_EMOJI=💚
